{
  "name": "@skapxd/nest",
  "version": "0.1.1",
  "description": "Layer marker decorators for NestJS applications checked by @skapxd/eslint-opinionated",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "yarn run test:unit",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:ui": "vitest --ui -c vitest.unit.config.ts",
    "report:unit": "npx vite preview --outDir test-reports/unit",
    "report:coverage": "npx vite preview --outDir test-reports/coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "keywords": [
    "nestjs",
    "decorators",
    "architecture",
    "layers",
    "eslint"
  ],
  "author": "skapxd",
  "license": "MIT",
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "reflect-metadata": "^0.1.12 || ^0.2.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/swagger": {
      "optional": true
    },
    "reflect-metadata": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "11.1.27",
    "@skapxd/eslint-opinionated": "8.5.0",
    "@vitest/coverage-v8": "4.0.17",
    "@vitest/ui": "4.0.17",
    "eslint": "^9",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8",
    "vitest": "4.0.17"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skapxd/nest.git"
  },
  "packageManager": "yarn@1.22.22"
}
